/***
--- !Test
solvers: [gecode]
expected: !Error
  regex: .*black-box propagator declaration must not have a body.*
***/

% A black-box propagator declaration must be bodyless; the body is generated by
% the compiler.

include "experimental/blackbox.mzn";

array[1..2] of var 1..3: x;

predicate q(list of var int: z) ::minizinc_value_propagator ::blackbox_exec("x") = true;

constraint q(x);

solve satisfy;
